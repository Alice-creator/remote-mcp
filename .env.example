MCP_SECRET=change-me-to-a-strong-random-token-32-chars-min
MCP_PORT=1000

# Default working directory for Claude Code (Windows path)
# Change this to your own project directory
CLAUDE_WORKING_DIR=C:/Project

# WSL home directory (used for running commands in WSL)
# Change this to your WSL username e.g. /home/yourname
WSL_HOME=/home/yourname
